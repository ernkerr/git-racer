{
  "buildCommand": "pnpm --filter @git-racer/client run build",
  "outputDirectory": "packages/client/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "includeFiles": "packages/{server,shared}/src/**",
      "maxDuration": 300,
      "memory": 2048
    }
  },
  "routes": [
    {
      "src": "/c/([a-zA-Z0-9_-]+)$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Twitterbot|facebookexternalhit|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot).*"
        }
      ],
      "dest": "/api/og/c/$1"
    },
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-seed",
      "schedule": "5 0 * * *"
    },
    {
      "path": "/api/cron/weekly-leagues",
      "schedule": "0 7 * * 1"
    }
  ]
}
