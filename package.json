{
  "name": "git-racer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:server": "pnpm --filter @git-racer/server run dev",
    "dev:client": "pnpm --filter @git-racer/client run dev",
    "build": "pnpm -r run build",
    "db:generate": "pnpm --filter @git-racer/server run db:generate",
    "db:migrate": "pnpm --filter @git-racer/server run db:migrate"
  },
  "dependencies": {
    "@hono/node-server": "^1.13",
    "@vercel/node": "^5.6.18",
    "drizzle-orm": "^0.45",
    "hono": "^4.7",
    "nanoid": "^5.1",
    "pg": "^8.13",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/node": "^22.0",
    "@types/pg": "^8.11",
    "typescript": "^5.7"
  }
}
